{
  "editable": true,
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "datasource": "HyperCache Logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "query": "message:\"HTTP request started\" AND container.name:hypercache-node1", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "10s" } }], "timeField": "@timestamp", "alias": "Node 1" },
        { "query": "message:\"HTTP request started\" AND container.name:hypercache-node2", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "10s" } }], "timeField": "@timestamp", "alias": "Node 2" },
        { "query": "message:\"HTTP request started\" AND container.name:hypercache-node3", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "10s" } }], "timeField": "@timestamp", "alias": "Node 3" }
      ]
    },
    {
      "title": "Response Status Codes",
      "type": "timeseries",
      "datasource": "HyperCache Logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "query": "message:\"status_code\" AND message:\"200\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "10s" } }], "timeField": "@timestamp", "alias": "200 OK" },
        { "query": "message:\"status_code\" AND message:\"404\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "10s" } }], "timeField": "@timestamp", "alias": "404 Not Found" },
        { "query": "message:\"status_code\" AND message:\"400\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "10s" } }], "timeField": "@timestamp", "alias": "400 Bad Request" }
      ]
    },
    {
      "title": "Cache Hit vs Miss",
      "type": "timeseries",
      "datasource": "HyperCache Logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "query": "message:\"GET operation successful\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "30s" } }], "timeField": "@timestamp", "alias": "Cache Hit" },
        { "query": "message:\"key not found\" OR message:\"not found\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "30s" } }], "timeField": "@timestamp", "alias": "Cache Miss" }
      ]
    },
    {
      "title": "Replication Throughput",
      "type": "timeseries",
      "datasource": "HyperCache Logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "query": "message:\"SUCCESS\" AND message:\"Replicated SET\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "30s" } }], "timeField": "@timestamp", "alias": "SET Replicated" },
        { "query": "message:\"SUCCESS\" AND message:\"Replicated DELETE\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "30s" } }], "timeField": "@timestamp", "alias": "DELETE Replicated" }
      ]
    },
    {
      "title": "Total Requests by Node",
      "type": "piechart",
      "datasource": "HyperCache Logs",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [{ "query": "message:\"HTTP request\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "terms", "field": "container.name.keyword", "id": "2", "settings": { "size": "5" } }], "timeField": "@timestamp" }]
    },
    {
      "title": "Replication Success vs Failure",
      "type": "piechart",
      "datasource": "HyperCache Logs",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        { "query": "message:\"SUCCESS\" AND message:Replicated", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "auto" } }], "timeField": "@timestamp", "alias": "Success" },
        { "query": "message:\"Failed to replicate\" OR message:\"Failed to apply replicated\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "auto" } }], "timeField": "@timestamp", "alias": "Failed" }
      ]
    },
    {
      "title": "Methods Breakdown (PUT/GET/DELETE/PATCH)",
      "type": "piechart",
      "datasource": "HyperCache Logs",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        { "query": "message:\"method\" AND message:\"PUT\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "auto" } }], "timeField": "@timestamp", "alias": "PUT" },
        { "query": "message:\"method\" AND message:\"GET\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "auto" } }], "timeField": "@timestamp", "alias": "GET" },
        { "query": "message:\"method\" AND message:\"DELETE\"", "metrics": [{ "type": "count", "id": "1" }], "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2", "settings": { "interval": "auto" } }], "timeField": "@timestamp", "alias": "DELETE" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["hypercache", "performance"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "HyperCache Performance Metrics",
  "uid": "hypercache-perf-v1"
}
